<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.96.3 -->
<interface>
  <!-- interface-name PackageWindow.ui -->
  <requires lib="gtk" version="4.0"/>
  <object class="GtkOverlay" id="PackageWindow">
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="hexpand">true</property>
        <property name="vexpand">true</property>
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="margin-bottom">10</property>
            <property name="spacing">5</property>
            <property name="halign">baseline</property>
            <child>
              <object class="GtkButton" id="install_button">
                <property name="halign">start</property>
                <property name="label">Install Selected</property>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="install_local_button">
                <property name="icon-name">folder-open-symbolic</property>
                <property name="tooltip-text">Install Local Packages</property>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="hexpand">true</property>
              </object>
            </child>
            <child>
              <object class="GtkSearchEntry" id="search_entry">
                <property name="placeholder-text">Search packages...</property>
                <property name="width-request">200</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="sync_button">
                <property name="icon-name">view-refresh-symbolic</property>
                <property name="tooltip-text">Sync</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkScrolledWindow">
            <property name="overlay-scrolling">false</property>
            <property name="hexpand">true</property>
            <property name="vexpand">true</property>
            <child>
              <object class="GtkColumnView" id="package_column_view">
                <property name="hexpand">true</property>
                <property name="show-column-separators">false</property>
                <property name="show-row-separators">false</property>
                <property name="vexpand">true</property>
                <child>
                  <object class="GtkColumnViewColumn" id="name_column">
                    <property name="expand">true</property>
                    <property name="title">Name</property>
                  </object>
                </child>
                <child>
                  <object class="GtkColumnViewColumn" id="version_column">
                    <property name="expand">true</property>
                    <property name="title">Version</property>
                  </object>
                </child>
                <child>
                  <object class="GtkColumnViewColumn" id="size_column">
                    <property name="expand">true</property>
                    <property name="title">Size</property>
                  </object>
                </child>
                <child>
                  <object class="GtkColumnViewColumn" id="repository_column">
                    <property name="expand">true</property>
                    <property name="title">Repository</property>
                  </object>
                </child>
                <child>
                  <object class="GtkColumnViewColumn" id="check_column">
                    <property name="fixed-width">60</property>
                    <property name="title"/>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
